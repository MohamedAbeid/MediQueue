@model MediQueue.Models.Clinic

@{
    ViewData["Title"] = "Clinic Details";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8">
            <h1>@Model.Name</h1>
            <hr />

            <div class="card">
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-3"><strong>Clinic ID:</strong></div>
                        <div class="col-md-9">@Model.ClinicID</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3"><strong>Address:</strong></div>
                        <div class="col-md-9">@Model.Address</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3"><strong>Phone:</strong></div>
                        <div class="col-md-9">@Model.PhoneNumber</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3"><strong>Doctors:</strong></div>
                        <div class="col-md-9">
                            @if (Model.Doctors != null && Model.Doctors.Count() > 0)
                            {
                                <ul class="list-group">
                                    @foreach (var doctor in Model.Doctors)
                                    {
                                        <li class="list-group-item">
                                            <strong>@doctor.FullName</strong>
                                            @if (!string.IsNullOrEmpty(doctor.Specialty))
                                            {
                                                <br />
                                                <small class="text-muted">Specialty: @doctor.Specialty</small>
                                            }
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <span class="text-muted">No doctors assigned</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-8">
            <a asp-action="Edit" asp-route-id="@Model.ClinicID" class="btn btn-warning">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a asp-action="Delete" asp-route-id="@Model.ClinicID" class="btn btn-danger">
                <i class="bi bi-trash"></i> Delete
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </div>
</div>
