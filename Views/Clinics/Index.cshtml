@model IEnumerable<MediQueue.Models.Clinic>

@{
    ViewData["Title"] = "Clinics";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>العيادات</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> إنشاء عيادة جديدة
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Count() == 0)
    {
        <div class="alert alert-info">
            No clinics found. <a asp-action="Create">Create one now</a>
        </div>
    }
    else
    {
        <div class="table-responsive" style="border: 3px solid black; border-radius: 0.375rem;">
            <table class="table table-striped table-hover align-middle m-0" style="border-collapse: collapse;">
                <thead class="table-dark sticky-top">
                    <tr>
                        <th class="text-center" style="width: 8%; border: 2px solid black;">بطاقة تعريف</th>
                        <th style="width: 20%; border: 2px solid black;">الاســم</th>
                        <th style="width: 25%; border: 2px solid black;">العنوان</th>
                        <th class="text-center" style="width: 12%; border: 2px solid black;">الهاتف</th>
                        <th class="text-center" style="width: 10%; border: 2px solid black;">الأطباء</th>
                        <th class="text-center" style="width: 25%; border: 2px solid black;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var clinic in Model)
                    {
                        <tr class="border-bottom">
                            <td class="text-center fw-semibold" style="border: 2px solid black;">@clinic.ClinicID</td>
                            <td style="border: 2px solid black;">
                                <span class="fw-semibold">@clinic.Name</span>
                            </td>
                            <td style="border: 2px solid black;">
                                <small class="text-muted">@clinic.Address</small>
                            </td>
                            <td class="text-center" style="border: 2px solid black;">
                                <a href="tel:@clinic.PhoneNumber" class="text-decoration-none">
                                    @clinic.PhoneNumber
                                </a>
                            </td>
                            <td class="text-center" style="border: 2px solid black;">
                                <span class="badge bg-info text-dark">@(clinic.Doctors?.Count() ?? 0)</span>
                            </td>
                            <td class="text-center" style="border: 2px solid black; padding: 0.75rem !important; white-space: nowrap;">
                                <a asp-action="Details" asp-route-id="@clinic.ClinicID" class="btn btn-sm btn-info"
                                    title="View Details">
                                    <i class="bi bi-eye"></i> عرض
                                </a>
                                <a asp-action="Edit" asp-route-id="@clinic.ClinicID" class="btn btn-sm btn-warning"
                                    title="Edit Clinic">
                                    <i class="bi bi-pencil"></i> تعديل
                                </a>
                                <a asp-action="Delete" asp-route-id="@clinic.ClinicID" class="btn btn-sm btn-danger"
                                    title="Delete Clinic">
                                    <i class="bi bi-trash"></i> حذف
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
