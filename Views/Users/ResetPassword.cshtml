@model MediQueue.ViewModel.ResetPasswordViewModel

@{
    ViewData["Title"] = "إعادة تعيين كلمة المرور";
}

<div class="container fade-in" style="max-width: 500px; padding-top: 4rem;">
    <div class="card" style="padding: 2.5rem 2rem;">
        <div style="text-align: center; margin-bottom: 2rem;">
            <div style="width: 64px; height: 64px; background: color-mix(in srgb, var(--danger) 12%, transparent); color: var(--danger); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem;">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <h1 style="font-size: 1.5rem; font-weight: 800; margin: 0;">إعادة تعيين كلمة المرور</h1>
            <p class="text-muted" style="margin-top: 0.5rem; font-size: 0.9rem;">
                أنت تقوم بتغيير كلمة المرور الخاصة بالمستخدم: 
                <strong style="color: var(--text-primary);">@Model.FullName</strong>
            </p>
        </div>

        <form asp-action="ResetPassword" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="margin-bottom: 1.5rem;"></div>

            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="FullName" />

            <div class="form-group">
                <label asp-for="NewPassword" class="form-label">كلمة المرور الجديدة</label>
                <input asp-for="NewPassword" class="form-input" placeholder="أدخل كلمة المرور الجديدة" dir="ltr" />
                <span asp-validation-for="NewPassword" class="form-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmNewPassword" class="form-label">تأكيد كلمة المرور الجديدة</label>
                <input asp-for="ConfirmNewPassword" class="form-input" placeholder="أعد إدخال كلمة المرور الجديدة" dir="ltr" />
                <span asp-validation-for="ConfirmNewPassword" class="form-error"></span>
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 2rem;">
                <button type="submit" class="btn btn-primary" style="flex: 1;">
                    حفظ التغييرات
                </button>
                <a asp-action="Index" class="btn btn-outline" style="flex: 1;">
                    إلغاء
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
