@model MediQueue.Models.User

@{
    ViewData["Title"] = "User Details";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8">
            <h1>@Model.FullName</h1>
            <hr />

            <div class="card">
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-3"><strong>User ID:</strong></div>
                        <div class="col-md-9">@Model.Id</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3"><strong>Username:</strong></div>
                        <div class="col-md-9">@Model.UserName</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3"><strong>Email:</strong></div>
                        <div class="col-md-9">@Model.Email</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3"><strong>Phone:</strong></div>
                        <div class="col-md-9">@Model.PhoneNumber</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3"><strong>Specialty:</strong></div>
                        <div class="col-md-9">
                            @if (!string.IsNullOrEmpty(Model.Specialty))
                            {
                                <span class="badge bg-success">@Model.Specialty</span>
                            }
                            else
                            {
                                <span class="text-muted">Not specified</span>
                            }
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3"><strong>Clinic:</strong></div>
                        <div class="col-md-9">
                            @if (Model.Clinic != null)
                            {
                                <a asp-controller="Clinics" asp-action="Details" asp-route-id="@Model.Clinic.ClinicID" class="badge bg-primary">
                                    @Model.Clinic.Name
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">Not assigned</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-8">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                <i class="bi bi-trash"></i> Delete
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </div>
</div>
