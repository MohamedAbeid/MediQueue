@model IEnumerable<MediQueue.Models.User>

@{
    ViewData["Title"] = "Users";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>المستخدمين</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="CreateDoctor" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> إضافة طبيب جديد
            </a>
            <a asp-action="Doctors" class="btn btn-primary">
                <i class="bi bi-person-check"></i> عرض الأطباء فقط
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Count() == 0)
    {
        <div class="alert alert-info">
            لا يوجد مستخدمين في النظام. يمكنك إضافة مستخدم جديد من خلال زر "إضافة طبيب جديد".
        </div>
    }
    else
    {
        <div class="table-responsive" style="border: 3px solid black; border-radius: 0.375rem;">
            <table class="table table-striped table-hover align-middle m-0" style="border-collapse: collapse;">
                <thead class="table-dark">
                    <tr>
                        <th class="text-center" style="width: 8%; border: 2px solid black;">بطاقة تعريف</th>
                        <th class="text-center" style="width: 8%; border: 2px solid black;">الاسم الكامل</th>
                        <th class="text-center" style="width: 8%; border: 2px solid black;">البريد الإلكتروني</th>
                        <th class="text-center" style="width: 8%; border: 2px solid black;">رقم الهاتف</th>
                        <th class="text-center" style="width: 8%; border: 2px solid black;">التخصص</th>
                        <th class="text-center" style="width: 8%; border: 2px solid black;">العيادة</th>
                        <th class="text-center" style="width: 8%; border: 2px solid black;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.Id.Substring(0, Math.Min(8, user.Id.Length))</td>
                            <td>@user.FullName</td>
                            <td>@user.Email</td>
                            <td>@user.PhoneNumber</td>
                            <td>
                                @if (!string.IsNullOrEmpty(user.Specialty))
                                {
                                    <span class="badge bg-success">@user.Specialty</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (user.Clinic != null)
                                {
                                    <span class="badge bg-primary">@user.Clinic.Name</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-center" style="border: 2px solid black; padding: 0.75rem !important; white-space: nowrap;">
                                <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-info">
                                    <i class="bi bi-eye"></i> View
                                </a>
                                <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
