@model IEnumerable<MediQueue.Models.User>

@{
    ViewData["Title"] = "Doctors";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Doctors</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to Users
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Count() == 0)
    {
        <div class="alert alert-info">
            No doctors found.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var doctor in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@doctor.FullName</h5>
                            <p class="card-text">
                                <strong>Specialty:</strong> @(doctor.Specialty ?? "Not specified")<br />
                                <strong>Email:</strong> @doctor.Email<br />
                                <strong>Phone:</strong> @doctor.PhoneNumber<br />
                                <strong>Clinic:</strong> @(doctor.Clinic?.Name ?? "Not assigned")
                            </p>
                        </div>
                        <div class="card-footer">
                            <a asp-action="Details" asp-route-id="@doctor.Id" class="btn btn-sm btn-info">
                                <i class="bi bi-eye"></i> View
                            </a>
                            <a asp-action="Edit" asp-route-id="@doctor.Id" class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
