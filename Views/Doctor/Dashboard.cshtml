@model IEnumerable<MediQueue.Models.Appointment>

@{
    ViewData["Title"] = "لوحة الطبيب";
    var upcomingAppointments = ViewBag.UpcomingAppointments as IEnumerable<MediQueue.Models.Appointment>;
}

<div class="container fade-in" style="padding-top: 2rem;">
    <div style="margin-bottom: 2rem;">
        <h1 class="section-title" style="margin: 0; font-size: 1.5rem;">مرحباً بك يا دكتور</h1>
        <p class="text-muted">هذه لمحة سريعة عن مواعيدك اليوم وحالتها.</p>
    </div>

    <!-- الإحصائيات -->
    <div class="grid grid-cols-3" style="grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); margin-bottom: 2.5rem;">
        
        <div class="card" style="display: flex; flex-direction: row; align-items: center; gap: 1rem; padding: 1.5rem;">
            <div style="background: color-mix(in srgb, var(--primary) 12%, transparent); color: var(--primary); width: 56px; height: 56px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </div>
            <div>
                <div class="text-secondary" style="font-size: 0.9rem; font-weight: 600; margin-bottom: 0.25rem;">مواعيد اليوم</div>
                <div style="font-size: 1.5rem; font-weight: 800; line-height: 1;">@ViewBag.TodaysCount</div>
            </div>
        </div>

        <div class="card" style="display: flex; flex-direction: row; align-items: center; gap: 1rem; padding: 1.5rem;">
            <div style="background: color-mix(in srgb, var(--success) 12%, transparent); color: var(--success); width: 56px; height: 56px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            </div>
            <div>
                <div class="text-secondary" style="font-size: 0.9rem; font-weight: 600; margin-bottom: 0.25rem;">المواعيد المكتملة</div>
                <div style="font-size: 1.5rem; font-weight: 800; line-height: 1;">@ViewBag.CompletedCount</div>
            </div>
        </div>

        <div class="card" style="display: flex; flex-direction: row; align-items: center; gap: 1rem; padding: 1.5rem;">
            <div style="background: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); width: 56px; height: 56px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div>
                <div class="text-secondary" style="font-size: 0.9rem; font-weight: 600; margin-bottom: 0.25rem;">إجمالي المواعيد المسجلة</div>
                <div style="font-size: 1.5rem; font-weight: 800; line-height: 1;">@ViewBag.TotalAppointments</div>
            </div>
        </div>

    </div>

    <div class="grid grid-cols-3" style="gap: 2rem;">
        <!-- مواعيد اليوم -->
        <div class="card" style="grid-column: span 2; padding: 1.5rem;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                <h2 style="font-size: 1.2rem; margin: 0; font-weight: 800;">مواعيد اليوم</h2>
                <a asp-action="Queue" class="btn btn-sm btn-primary">إدارة الطابور</a>
            </div>

            @if (Model != null && Model.Any())
            {
                <div class="table-wrap">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>الوقت</th>
                                <th>المريض</th>
                                <th>رقم الهاتف</th>
                                <th style="text-align: center;">الحالة</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var apt in Model)
                            {
                                <tr>
                                    <td dir="ltr" style="font-weight: 700; color: var(--primary);">@apt.AppointmentTime.ToString(@"hh\:mm")</td>
                                    <td style="font-weight: 600;">@apt.Patient</td>
                                    <td style="text-align: center;">
                                        @if (apt.Status == MediQueue.Models.AppointmentStatus.Booked)
                                        {
                                            <span class="status-badge status-booked">في الانتظار</span>
                                        }
                                        else if (apt.Status == MediQueue.Models.AppointmentStatus.Completed)
                                        {
                                            <span class="status-badge status-completed">مكتمل</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div style="text-align: center; padding: 3rem 1rem; color: var(--text-muted);">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom: 1rem; opacity: 0.5;">
                        <circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>
                    </svg>
                    <div style="font-weight: 600;">لا يوجد لديك مواعيد مسجلة لليوم.</div>
                </div>
            }
        </div>

        <!-- المواعيد القادمة -->
        <div class="card" style="grid-column: span 1; padding: 1.5rem;">
            <h2 style="font-size: 1.1rem; margin: 0 0 1.5rem 0; font-weight: 800; border-bottom: 1px solid var(--border); padding-bottom: 0.75rem;">مواعيد قادمة</h2>
            
            @if (upcomingAppointments != null && upcomingAppointments.Any())
            {
                <div style="display: flex; flex-direction: column; gap: 1rem;">
                    @foreach (var apt in upcomingAppointments)
                    {
                        <div style="padding: 1rem; border-radius: var(--radius); background: color-mix(in srgb, var(--background) 50%, transparent); border: 1px solid var(--border);">
                            <div style="font-weight: 700; margin-bottom: 0.25rem;">@apt.Patient</div>
                            <div style="display: flex; justify-content: space-between; font-size: 0.85rem; color: var(--text-secondary);">
                                <span dir="ltr">@apt.AppointmentDate.ToString("yyyy-MM-dd")</span>
                                <span dir="ltr" style="font-weight: 600; color: var(--accent);">@apt.AppointmentTime.ToString(@"hh\:mm")</span>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div style="text-align: center; padding: 2rem 1rem; color: var(--text-muted); font-size: 0.9rem;">
                    لا يوجد مواعيد قادمة مجدولة.
                </div>
            }
        </div>
    </div>
</div>
