@model IEnumerable<MediQueue.Models.Queue>

@{
    ViewData["Title"] = "إدارة الطابور";
}

<div class="container fade-in" style="padding-top: 2rem; max-width: 900px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
        <div>
            <h1 class="section-title" style="margin: 0;">الطابور الحي</h1>
            <p class="text-muted" style="margin-top: 0.5rem;">إدارة ترتيب المرضى المنتظرين اليوم.</p>
        </div>
        <a asp-action="Dashboard" class="btn btn-outline">الرجوع للرئيسية</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    @if (Model != null && Model.Any())
    {
        <div style="display: flex; flex-direction: column; gap: 1rem;">
            @foreach (var item in Model)
            {
                var isFirst = item.Position == 1;
                <div class="card" style="padding: 1.5rem; display: flex; align-items: center; justify-content: space-between; border-right: 4px solid @(isFirst ? "var(--primary)" : "var(--border)"); background: @(isFirst ? "color-mix(in srgb, var(--primary) 3%, var(--surface))" : "var(--surface)");">
                    
                    <div style="display: flex; align-items: center; gap: 1.5rem;">
                        <div style="width: 48px; height: 48px; border-radius: 50%; background: @(isFirst ? "var(--primary)" : "var(--background)"); color: @(isFirst ? "white" : "var(--text-secondary)"); display: flex; align-items: center; justify-content: center; font-size: 1.25rem; font-weight: 800; border: 1px solid @(isFirst ? "transparent" : "var(--border)");">
                            @item.Position
                        </div>
                        
                        <div>
                            <div style="font-weight: 700; font-size: 1.1rem; color: var(--text-primary); margin-bottom: 0.25rem;">
                                @item.Appointment?.Patient
                            </div>
                            <div style="display: flex; gap: 1rem; font-size: 0.85rem; color: var(--text-secondary);">
                                <span dir="ltr">الوقت المتوقع: @item.EstimatedTime.ToString(@"hh\:mm")</span>
                                <span dir="ltr">رقم الحجز: #@item.AppointmentID</span>
                            </div>
                        </div>
                    </div>

                    @if (isFirst)
                    {
                        <form asp-action="AdvanceQueue" method="post">
                            <input type="hidden" name="queueId" value="@item.QueueID" />
                            <button type="submit" class="btn btn-primary">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-inline-end: 0.5rem;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                                إنهاء الكشف واستدعاء التالي
                            </button>
                        </form>
                    }
                    else
                    {
                        <div style="padding: 0.5rem 1rem; border-radius: var(--radius); background: var(--background); color: var(--text-muted); font-size: 0.9rem;">
                            في الانتظار
                        </div>
                    }

                </div>
            }
        </div>
    }
    else
    {
        <div class="card" style="text-align: center; padding: 4rem 2rem;">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color:var(--success); margin-bottom:1rem">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
            <h3 style="color:var(--text-secondary); margin-bottom: 0.5rem">الطابور فارغ</h3>
            <p style="color:var(--text-muted);">لا يوجد مرضى في طابور الانتظار حالياً.</p>
        </div>
    }
</div>
