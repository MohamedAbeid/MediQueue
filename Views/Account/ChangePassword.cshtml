@model MediQueue.ViewModel.ChangePasswordViewModel

@{
    ViewData["Title"] = "تغيير كلمة المرور";
}

<div class="container fade-in" style="max-width: 500px; padding-top: 4rem;">
    <div class="card" style="padding: 2.5rem 2rem;">
        <div style="text-align: center; margin-bottom: 2rem;">
            <div style="width: 64px; height: 64px; background: color-mix(in srgb, var(--primary) 12%, transparent); color: var(--primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem;">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <h1 style="font-size: 1.5rem; font-weight: 800; margin: 0;">تغيير كلمة المرور</h1>
            <p class="text-muted" style="margin-top: 0.5rem; font-size: 0.9rem;">الرجاء إدخال كلمة المرور الحالية والجديدة لتحديث حسابك.</p>
        </div>

        <form asp-action="ChangePassword" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="margin-bottom: 1.5rem;"></div>

            <div class="form-group">
                <label asp-for="CurrentPassword" class="form-label">كلمة المرور الحالية</label>
                <input asp-for="CurrentPassword" class="form-input" placeholder="أدخل كلمة المرور الحالية" dir="ltr" />
                <span asp-validation-for="CurrentPassword" class="form-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="NewPassword" class="form-label">كلمة المرور الجديدة</label>
                <input asp-for="NewPassword" class="form-input" placeholder="أدخل كلمة المرور الجديدة" dir="ltr" />
                <span asp-validation-for="NewPassword" class="form-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmNewPassword" class="form-label">تأكيد كلمة المرور الجديدة</label>
                <input asp-for="ConfirmNewPassword" class="form-input" placeholder="أعد إدخال كلمة المرور الجديدة" dir="ltr" />
                <span asp-validation-for="ConfirmNewPassword" class="form-error"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-block" style="margin-top: 1rem;">
                حفظ التغييرات
            </button>
            
            <div style="text-align: center; margin-top: 1rem;">
                <a href="javascript:history.back()" class="text-muted" style="font-size: 0.9rem; text-decoration: none;">إلغاء والرجوع للخلف</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
