@model IEnumerable<MediQueue.Models.Appointment>

@{
    ViewData["Title"] = "My Appointments";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>My Appointments</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Book New
            </a>
        </div>
    </div>

    @if (Model.Count() == 0)
    {
        <div class="alert alert-info">
            You don't have any appointments. <a asp-action="Create">Book one now</a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var appointment in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@appointment.Doctor?.FullName</h5>
                            <p class="card-text">
                                <strong>Date:</strong> @appointment.AppointmentDate.ToString("MMM dd, yyyy")<br />
                                <strong>Time:</strong> @appointment.AppointmentTime.ToString(@"hh\:mm")<br />
                                <strong>Status:</strong>
                                @if (appointment.Status == MediQueue.Models.AppointmentStatus.Booked)
                                {
                                    <span class="badge bg-success">Booked</span>
                                }
                                else if (appointment.Status == MediQueue.Models.AppointmentStatus.Completed)
                                {
                                    <span class="badge bg-info">Completed</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Cancelled</span>
                                }
                            </p>
                        </div>
                        <div class="card-footer">
                            <a asp-action="Details" asp-route-id="@appointment.AppointmentID" class="btn btn-sm btn-info">
                                <i class="bi bi-eye"></i> View
                            </a>
                            <a asp-action="Edit" asp-route-id="@appointment.AppointmentID" class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
