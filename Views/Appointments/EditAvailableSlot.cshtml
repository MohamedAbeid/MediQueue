@model MediQueue.ViewModel.AvailableSlotViewModel

@{
    ViewData["Title"] = "Edit Available Slot";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>تعديل الموعد المتاح</h1>
            <hr />

            <form asp-action="EditAvailableSlot" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <input type="hidden" asp-for="SlotID" />

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Date" class="form-label">التاريخ</label>
                            <input asp-for="Date" type="date" class="form-control" />
                            <span asp-validation-for="Date" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="StartTime" class="form-label">وقت البداية</label>
                            <input asp-for="StartTime" type="time" class="form-control" />
                            <span asp-validation-for="StartTime" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="EndTime" class="form-label">وقت النهاية</label>
                            <input asp-for="EndTime" type="time" class="form-control" />
                            <span asp-validation-for="EndTime" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="MaxPatients" class="form-label">الحد الأقصى للمرضى</label>
                            <input asp-for="MaxPatients" type="number" class="form-control" min="1" max="50" />
                            <small class="form-text text-muted">يجب أن يكون بين 1 و 50</small>
                            <span asp-validation-for="MaxPatients" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12">
                        <div class="alert alert-info">
                            <strong>الحجوزات الحالية:</strong> @Model.AvailableSlotsCount / @Model.MaxPatients
                        </div>
                    </div>
                </div>

                <hr />

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle"></i> تحديث الموعد
                    </button>
                    <a asp-action="ManageAvailableSlots" class="btn btn-secondary">
                        <i class="bi bi-x-circle"></i> إلغاء
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
