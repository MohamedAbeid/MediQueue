@model MediQueue.ViewModel.AvailableSlotViewModel

@{
    ViewData["Title"] = "تعديل الموعد المتاح";
}

<div class="container fade-in" style="max-width: 600px; padding-top: 2rem;">
    <div class="card">
        <h1 class="section-title" style="margin-top: 0; text-align: center;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: middle; margin-inline-end: 0.5rem;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            تعديل موعد متاح
        </h1>
        <hr style="border: none; border-top: 1px solid var(--border); margin-block: 1rem 1.5rem;" />

        @if (ViewData.ModelState.Values.SelectMany(v => v.Errors).Any())
        {
            <div class="alert alert-danger" style="margin-bottom: 1.5rem;">
                <ul style="margin: 0; padding-inline-start: 1.5rem;">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }

        <div class="alert alert-info" style="margin-bottom: 1.5rem; display: flex; align-items: center; gap: 1rem;">
            <div style="font-size: 1.5rem;">ℹ️</div>
            <div>
                <strong>حجوزات مسجلة:</strong> هذا الموعد يحتوي على <strong>@Model.CurrentBookings</strong> حجز مسبق. تأكد من أن الحد الأقصى الجديد لا يقل عن هذا العدد.
            </div>
        </div>

        <form asp-action="EditAvailableSlot" method="post">
            <input type="hidden" asp-for="SlotID" />
            <input type="hidden" asp-for="CurrentBookings" />

            <div class="form-group">
                <label asp-for="Date" class="form-label">التاريخ <span style="color: var(--danger);">*</span></label>
                <input asp-for="Date" type="date" class="form-input" min="@DateTime.Today.ToString("yyyy-MM-dd")" dir="ltr" required />
                <span asp-validation-for="Date" class="form-error"></span>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div class="form-group">
                    <label asp-for="StartTime" class="form-label">وقت البداية <span style="color: var(--danger);">*</span></label>
                    <input asp-for="StartTime" type="time" class="form-input" dir="ltr" required />
                    <span asp-validation-for="StartTime" class="form-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="EndTime" class="form-label">وقت النهاية <span style="color: var(--danger);">*</span></label>
                    <input asp-for="EndTime" type="time" class="form-input" dir="ltr" required />
                    <span asp-validation-for="EndTime" class="form-error"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="MaxPatients" class="form-label">الحد الأقصى للمرضى <span style="color: var(--danger);">*</span></label>
                <input asp-for="MaxPatients" type="number" class="form-input" min="@(Math.Max(1, Model.CurrentBookings))" max="50" dir="ltr" required />
                <span style="font-size: 0.85rem; color: var(--text-muted); margin-top: 0.25rem; display: block;">لا يمكن أن يقل عن عدد الحجوزات الحالية (@Model.CurrentBookings)</span>
                <span asp-validation-for="MaxPatients" class="form-error"></span>
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 2rem;">
                <button type="submit" class="btn btn-warning" style="flex: 1; color: white;">
                    حفظ التعديلات
                </button>
                <a asp-action="ManageAvailableSlots" class="btn btn-outline" style="flex: 1;">
                    إلغاء
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
