@model IEnumerable<MediQueue.Models.Appointment>

@{
    ViewData["Title"] = "Upcoming Appointments";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Upcoming Appointments</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    @if (Model.Count() == 0)
    {
        <div class="alert alert-info">
            You have no upcoming appointments.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var appointment in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card h-100 border-primary">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">@appointment.Doctor?.FullName</h5>
                        </div>
                        <div class="card-body">
                            <p class="card-text">
                                <strong>📅 Date:</strong> @appointment.AppointmentDate.ToString("dddd, MMM dd, yyyy")<br />
                                <strong>🕐 Time:</strong> @appointment.AppointmentTime.ToString(@"hh\:mm")<br />
                                <strong>📍 Location:</strong> @appointment.Doctor?.Clinic?.Name<br />
                                <strong>Status:</strong>
                                @if (appointment.Status == MediQueue.Models.AppointmentStatus.Booked)
                                {
                                    <span class="badge bg-success">Booked</span>
                                }
                                else if (appointment.Status == MediQueue.Models.AppointmentStatus.Completed)
                                {
                                    <span class="badge bg-info">Completed</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Cancelled</span>
                                }
                            </p>
                        </div>
                        <div class="card-footer">
                            <a asp-action="Details" asp-route-id="@appointment.AppointmentID" class="btn btn-sm btn-info">
                                <i class="bi bi-eye"></i> Details
                            </a>
                            <a asp-action="Cancel" asp-route-id="@appointment.AppointmentID" class="btn btn-sm btn-danger">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
