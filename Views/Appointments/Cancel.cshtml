@model MediQueue.Models.Appointment

@{
    ViewData["Title"] = "Cancel Appointment";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <h2 class="text-danger">Cancel Appointment</h2>
            <hr />
            <p class="alert alert-warning">
                <strong>Warning!</strong> Are you sure you want to cancel this appointment?
            </p>

            <div class="card">
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-4"><strong>ID:</strong></div>
                        <div class="col-md-8">@Model.AppointmentID</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-4"><strong>Patient:</strong></div>
                        <div class="col-md-8">@Model.Patient?.FullName</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-4"><strong>Doctor:</strong></div>
                        <div class="col-md-8">@Model.Doctor?.FullName</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-4"><strong>Date:</strong></div>
                        <div class="col-md-8">@Model.AppointmentDate.ToString("MMM dd, yyyy")</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-4"><strong>Time:</strong></div>
                        <div class="col-md-8">@Model.AppointmentTime.ToString(@"hh\:mm")</div>
                    </div>
                </div>
            </div>

            <form asp-action="Cancel" method="post" class="mt-4">
                <input type="hidden" asp-for="AppointmentID" />
                <button type="submit" class="btn btn-danger btn-lg">
                    <i class="bi bi-x-circle"></i> Cancel Appointment
                </button>
                <a asp-action="Details" asp-route-id="@Model.AppointmentID" class="btn btn-secondary btn-lg">
                    <i class="bi bi-arrow-left"></i> Go Back
                </a>
            </form>
        </div>
    </div>
</div>
