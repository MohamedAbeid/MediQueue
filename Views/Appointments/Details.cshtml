@model MediQueue.Models.Appointment

@{
    ViewData["Title"] = "Appointment Details";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8">
            <h1>Appointment Details</h1>
            <hr />

            <div class="card">
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-3"><strong>Appointment ID:</strong></div>
                        <div class="col-md-9">@Model.AppointmentID</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3"><strong>Patient:</strong></div>
                        <div class="col-md-9">@Model.Patient?.FullName</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3"><strong>Doctor:</strong></div>
                        <div class="col-md-9">@Model.Doctor?.FullName</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3"><strong>Date:</strong></div>
                        <div class="col-md-9">@Model.AppointmentDate.ToString("dddd, MMMM dd, yyyy")</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3"><strong>Time:</strong></div>
                        <div class="col-md-9">@Model.AppointmentTime.ToString(@"hh\:mm")</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3"><strong>Status:</strong></div>
                        <div class="col-md-9">
                            @if (Model.Status == MediQueue.Models.AppointmentStatus.Booked)
                            {
                                <span class="badge bg-success">Booked</span>
                            }
                            else if (Model.Status == MediQueue.Models.AppointmentStatus.Completed)
                            {
                                <span class="badge bg-info">Completed</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Cancelled</span>
                            }
                        </div>
                    </div>
                    @if (Model.Queue != null)
                    {
                        <div class="row mb-3">
                            <div class="col-md-3"><strong>Queue Position:</strong></div>
                            <div class="col-md-9">@Model.Queue.Position</div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-3"><strong>Estimated Time:</strong></div>
                            <div class="col-md-9">@Model.Queue.EstimatedTime.ToString("hh:mm tt")</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-8">
            <a asp-action="Edit" asp-route-id="@Model.AppointmentID" class="btn btn-warning">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a asp-action="Cancel" asp-route-id="@Model.AppointmentID" class="btn btn-danger">
                <i class="bi bi-x-circle"></i> Cancel
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </div>
</div>
