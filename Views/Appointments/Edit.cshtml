@model MediQueue.ViewModel.AppointmentVM

@{
    ViewData["Title"] = "Edit Appointment";
    var doctors = ViewData["Doctors"] as IEnumerable<MediQueue.Models.User> ?? new List<MediQueue.Models.User>();
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>Edit Appointment</h1>
            <hr />

            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <input type="hidden" asp-for="AppointmentID" />

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="PatientID" class="form-label">Patient ID</label>
                            <input asp-for="PatientID" class="form-control" disabled />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="DoctorID" class="form-label">Doctor</label>
                            <select asp-for="DoctorID" class="form-control" asp-items="@(new SelectList(doctors, "Id", "FullName"))">
                                <option value="">-- Select Doctor --</option>
                            </select>
                            <span asp-validation-for="DoctorID" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="AppointmentDate" class="form-label">Appointment Date</label>
                            <input asp-for="AppointmentDate" type="date" class="form-control" />
                            <span asp-validation-for="AppointmentDate" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="AppointmentTime" class="form-label">Appointment Time</label>
                            <input asp-for="AppointmentTime" type="time" class="form-control" />
                            <span asp-validation-for="AppointmentTime" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-check-circle"></i> Update
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.AppointmentID" class="btn btn-secondary btn-lg">
                        <i class="bi bi-x-circle"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
