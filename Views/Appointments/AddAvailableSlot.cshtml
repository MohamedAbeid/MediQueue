@model MediQueue.ViewModel.AvailableSlotViewModel

@{
    ViewData["Title"] = "إضافة موعد متاح";
}

<div class="container fade-in" style="max-width: 600px; padding-top: 2rem;">
    <div class="card">
        <h1 class="section-title" style="margin-top: 0; text-align: center;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: middle; margin-inline-end: 0.5rem;"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="12" y1="14" x2="12" y2="18"/><line x1="10" y1="16" x2="14" y2="16"/></svg>
            إضافة موعد جديد
        </h1>
        <hr style="border: none; border-top: 1px solid var(--border); margin-block: 1rem 1.5rem;" />

        @if (ViewData.ModelState.Values.SelectMany(v => v.Errors).Any())
        {
            <div class="alert alert-danger" style="margin-bottom: 1.5rem;">
                <ul style="margin: 0; padding-inline-start: 1.5rem;">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }

        <form asp-action="AddAvailableSlot" method="post">
            <div class="form-group">
                <label asp-for="Date" class="form-label">التاريخ <span style="color: var(--danger);">*</span></label>
                <input asp-for="Date" type="date" class="form-input" min="@DateTime.Today.ToString("yyyy-MM-dd")" dir="ltr" required />
                <span asp-validation-for="Date" class="form-error"></span>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div class="form-group">
                    <label asp-for="StartTime" class="form-label">وقت البداية <span style="color: var(--danger);">*</span></label>
                    <input asp-for="StartTime" type="time" class="form-input" dir="ltr" required />
                    <span asp-validation-for="StartTime" class="form-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="EndTime" class="form-label">وقت النهاية <span style="color: var(--danger);">*</span></label>
                    <input asp-for="EndTime" type="time" class="form-input" dir="ltr" required />
                    <span asp-validation-for="EndTime" class="form-error"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="MaxPatients" class="form-label">الحد الأقصى للمرضى <span style="color: var(--danger);">*</span></label>
                <input asp-for="MaxPatients" type="number" class="form-input" min="1" max="50" dir="ltr" required />
                <span style="font-size: 0.85rem; color: var(--text-muted); margin-top: 0.25rem; display: block;">حدد العدد الذي تستطيع استقباله خلال هذه الفترة (1-50)</span>
                <span asp-validation-for="MaxPatients" class="form-error"></span>
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 2rem;">
                <button type="submit" class="btn btn-primary" style="flex: 1;">
                    حفظ وإضافة
                </button>
                <a asp-action="ManageAvailableSlots" class="btn btn-outline" style="flex: 1;">
                    إلغاء
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
