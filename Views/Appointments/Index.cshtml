@model IEnumerable<MediQueue.Models.Appointment>

@{
    ViewData["Title"] = "Appointments";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Appointments</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Book Appointment
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Count() == 0)
    {
        <div class="alert alert-info">
            No appointments found. <a asp-action="Create">Book one now</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Patient</th>
                        <th>Doctor</th>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var appointment in Model)
                    {
                        <tr>
                            <td>@appointment.AppointmentID</td>
                            <td>@appointment.Patient?.FullName</td>
                            <td>@appointment.Doctor?.FullName</td>
                            <td>@appointment.AppointmentDate.ToString("MMM dd, yyyy")</td>
                            <td>@appointment.AppointmentTime.ToString(@"hh\:mm")</td>
                            <td>
                                @if (appointment.Status == MediQueue.Models.AppointmentStatus.Booked)
                                {
                                    <span class="badge bg-success">Booked</span>
                                }
                                else if (appointment.Status == MediQueue.Models.AppointmentStatus.Completed)
                                {
                                    <span class="badge bg-info">Completed</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Cancelled</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@appointment.AppointmentID" class="btn btn-sm btn-info">
                                    <i class="bi bi-eye"></i> View
                                </a>
                                <a asp-action="Edit" asp-route-id="@appointment.AppointmentID" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a asp-action="Cancel" asp-route-id="@appointment.AppointmentID" class="btn btn-sm btn-danger">
                                    <i class="bi bi-x-circle"></i> Cancel
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
